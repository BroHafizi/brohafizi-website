var currentFilter = 'all';
var lbCurrent = 0;

window.renderGallery = function(filter) {
  var grid = document.getElementById('gallery-grid');
  grid.innerHTML = '';
  var filtered = filter === 'all' ? galleryData : galleryData.filter(img => img.category === filter);
  
  filtered.forEach(function(img, idx) {
    var item = document.createElement('div');
    item.className = 'masonry-item';
    item.innerHTML = '<img src="' + img.url + '" alt="' + img.caption + '"><div class="masonry-overlay"><div class="masonry-caption">' + img.caption + '</div></div>';
    item.onclick = function() { window.openLightbox(galleryData.indexOf(img)); };
    grid.appendChild(item);
  });
};

window.filterGallery = function(cat) {
  currentFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
  event.target.closest('.filter-btn').classList.add('active');
  window.renderGallery(cat);
};

window.openLightbox = function(idx) {
  lbCurrent = idx;
  var img = galleryData[idx];
  document.getElementById('lb-img').src = img.url;
  document.getElementById('lb-caption').textContent = img.caption;
  document.getElementById('lb-counter').textContent = (idx + 1) + ' / ' + galleryData.length;
  document.getElementById('lightbox').classList.add('active');
  document.body.style.overflow = 'hidden';
};

window.closeLightbox = function(e) {
  if (!e || e.target.id === 'lightbox' || e.target.classList.contains('lb-close')) {
    document.getElementById('lightbox').classList.remove('active');
    document.body.style.overflow = '';
  }
};

window.lbNav = function(d) {
  lbCurrent = (lbCurrent + d + galleryData.length) % galleryData.length;
  var img = galleryData[lbCurrent];
  document.getElementById('lb-img').src = img.url;
  document.getElementById('lb-caption').textContent = img.caption;
  document.getElementById('lb-counter').textContent = (lbCurrent + 1) + ' / ' + galleryData.length;
};

document.addEventListener('keydown', function(e) {
  var lb = document.getElementById('lightbox');
  if (lb && lb.classList.contains('active')) {
    if (e.key === 'ArrowLeft') window.lbNav(-1);
    if (e.key === 'ArrowRight') window.lbNav(1);
    if (e.key === 'Escape') window.closeLightbox();
  }
});

window.renderGallery('all');
</script>

</Layout>
