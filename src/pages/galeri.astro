document.addEventListener("DOMContentLoaded", function() {
  window.buildGrid("grid-korporat", korporatPhotos, "korporat", "Korporat & Training");
  window.buildGrid("grid-tokoh", tokohPhotos, "tokoh", "Bersama Tokoh & Ulama");

  window.allPhotos = [];
  window.korporatPhotos.forEach(function(p) { allPhotos.push({url:p.url, caption:p.caption, section:"Korporat & Training"}); });
  window.tokohPhotos.forEach(function(p) { allPhotos.push({url:p.url, caption:p.caption, section:"Bersama Tokoh & Ulama"}); });

  document.getElementById("count-all").textContent = window.allPhotos.length;
  document.getElementById("count-korporat").textContent = window.korporatPhotos.length;
  document.getElementById("count-tokoh").textContent = window.tokohPhotos.length;
  document.getElementById("label-korporat").textContent = window.korporatPhotos.length + " gambar";
  document.getElementById("label-tokoh").textContent = window.tokohPhotos.length + " gambar";

  document.addEventListener("keydown", function(e) {
    if (!document.getElementById("lightbox").classList.contains("active")) return;
    if (e.key === "ArrowLeft") window.lbNav(-1);
    if (e.key === "ArrowRight") window.lbNav(1);
    if (e.key === "Escape") window.closeLb();
  });
});

window.buildGrid = function(gridId, photos, section, sectionLabel) {
  var grid = document.getElementById(gridId);
  if (!grid) return;
  var offset = section === "korporat" ? 0 : window.korporatPhotos.length;
  photos.forEach(function(p, i) {
    var item = document.createElement("div");
    item.className = "photo-item";
    var idx = offset + i;
    item.innerHTML = '<img src="' + p.url + '" alt="' + p.caption + '" loading="lazy">' +
      '<div class="photo-overlay"><div class="photo-caption">' + p.caption + '</div></div>' +
      '<div class="photo-num">' + (i+1) + '</div>';
    item.onclick = function() { window.openLb(idx); };
    grid.appendChild(item);
  });
}

window.openLb = function(idx) {
  lbCur = idx;
  window.updateLb();
  document.getElementById("lightbox").classList.add("active");
  document.body.style.overflow = "hidden";
}

window.updateLb = function() {
  var p = window.allPhotos[lbCur];
  document.getElementById("lbImg").src = p.url;
  document.getElementById("lbImg").alt = p.caption;
  document.getElementById("lbCap").textContent = p.caption;
  document.getElementById("lbTag").textContent = p.section;
  document.getElementById("lbCtr").textContent = (lbCur+1) + " / " + window.allPhotos.length;
}

window.lbNav = function(d) {
  lbCur = (lbCur + d + window.allPhotos.length) % window.allPhotos.length;
  window.updateLb();
}

window.closeLb = function() {
  document.getElementById("lightbox").classList.remove("active");
  document.body.style.overflow = "";
}

window.lbBg = function(e) {
  if (e.target === document.getElementById("lightbox")) window.closeLb();
}

window.filterGallery = function(type, btn) {
  document.querySelectorAll(".filter-btn").forEach(function(b) { b.classList.remove("active"); });
  btn.classList.add("active");
  document.querySelectorAll(".gallery-section").forEach(function(s) {
    s.style.display = (type === "all" || s.getAttribute("data-section") === type) ? "block" : "none";
  });
}</script>


<div class="lightbox" id="lightbox" onclick="window.lbBg(event)">
  <button class="lb-close" onclick="window.closeLb()">&times;</button>
  <button class="lb-nav lb-prev" onclick="window.lbNav(-1);event.stopPropagation()">&#8592;</button>
  <button class="lb-nav lb-next" onclick="window.lbNav(1);event.stopPropagation()">&#8594;</button>
  <div class="lb-content">
    <img class="lb-img" id="lbImg" src="" alt="">
    <div class="lb-footer">
      <div><div class="lb-section-tag" id="lbTag"></div><div class="lb-caption" id="lbCap"></div></div>
      <div class="lb-counter" id="lbCtr"></div>
    </div>
  </div>
</div>

</Layout>
