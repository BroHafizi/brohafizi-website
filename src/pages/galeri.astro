---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Galeri | BroHafizi" description="Koleksi gambar dakwah lapangan, interfaith, program dakwah dan ceramah BroHafizi dari seluruh Malaysia." canonical="https://brohafizi.com/galeri">

<style is:global>
.page-header{background:#0d1b3e;padding:64px 5% 48px;position:relative;overflow:hidden}
.page-header-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0d1b3e 0%,#162d5e 50%,#0d1b3e 100%)}
.page-header-inner{position:relative;z-index:2;max-width:1200px;margin:0 auto}
.page-header-label{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#6b8dba;margin-bottom:12px;font-weight:500}
.page-header-title{font-family:"Playfair Display",serif;font-size:clamp(28px,5vw,48px);font-weight:700;color:#fff;line-height:1.2;margin-bottom:16px}
.page-header-sub{font-size:15px;color:#6b8dba;max-width:560px;line-height:1.7}

.filter-bar{background:#fff;border-bottom:1px solid #e8e4dc;padding:0 5%;position:sticky;top:64px;z-index:90}
.filter-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;gap:6px;padding:14px 0;overflow-x:auto;scrollbar-width:none}
.filter-inner::-webkit-scrollbar{display:none}
.filter-btn{padding:7px 18px;border-radius:20px;border:1px solid #e0ddd6;background:#fff;font-size:13px;color:#666;cursor:pointer;white-space:nowrap;transition:all 0.15s;font-family:"DM Sans",sans-serif}
.filter-btn:hover{border-color:#0d1b3e;color:#0d1b3e}
.filter-btn.active{background:#0d1b3e;color:#fff;border-color:#0d1b3e}
.filter-count{font-size:11px;background:#f0ede8;color:#999;padding:2px 7px;border-radius:10px;margin-left:4px}
.filter-btn.active .filter-count{background:rgba(255,255,255,0.2);color:#fff}

.gallery-main{max-width:1200px;margin:0 auto;padding:40px 5% 60px}

/* Masonry layout */
.masonry-grid{columns:4;column-gap:12px}
.masonry-item{break-inside:avoid;margin-bottom:12px;cursor:pointer;position:relative;overflow:hidden;border-radius:6px;display:block}
.masonry-item img{width:100%;display:block;transition:transform 0.3s ease}
.masonry-item:hover img{transform:scale(1.04)}
.masonry-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(13,27,62,0.7) 0%,transparent 50%);opacity:0;transition:opacity 0.3s;display:flex;align-items:flex-end;padding:12px}
.masonry-item:hover .masonry-overlay{opacity:1}
.masonry-caption{color:#fff;font-size:11px;font-weight:500;line-height:1.4}

.section-header{display:flex;align-items:center;gap:12px;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid #e8e4dc}
.section-title{font-family:"Playfair Display",serif;font-size:22px;font-weight:700;color:#0d1b3e}
.section-badge{font-size:11px;background:#f0ede8;color:#888;padding:3px 10px;border-radius:10px}
.section-desc{font-size:14px;color:#666;line-height:1.7;margin-top:8px;max-width:700px}

.gallery-section{margin-bottom:48px}
.gallery-section.hidden{display:none}

/* Lightbox */
.lightbox{display:none;position:fixed;inset:0;background:rgba(6,15,34,0.97);z-index:999;align-items:center;justify-content:center;padding:20px}
.lightbox.active{display:flex}
.lb-inner{position:relative;max-width:90vw;max-height:90vh;display:flex;align-items:center;justify-content:center}
.lb-img{max-width:90vw;max-height:85vh;object-fit:contain;border-radius:4px}
.lb-close{position:fixed;top:20px;right:24px;background:rgba(255,255,255,0.1);border:none;color:#fff;font-size:24px;width:44px;height:44px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.15s}
.lb-close:hover{background:rgba(255,255,255,0.2)}
.lb-nav{position:fixed;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.1);border:none;color:#fff;font-size:20px;width:48px;height:48px;border-radius:50%;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:background 0.15s}
.lb-nav:hover{background:rgba(255,255,255,0.2)}
.lb-prev{left:16px}
.lb-next{right:16px}
.lb-caption{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);color:#aaa;font-size:13px;text-align:center;max-width:600px}
.lb-counter{position:fixed;top:20px;left:50%;transform:translateX(-50%);color:#aaa;font-size:12px}

@media(max-width:900px){.masonry-grid{columns:3}}
@media(max-width:600px){.masonry-grid{columns:2;column-gap:8px}.masonry-item{margin-bottom:8px}.lb-nav{display:none}}
</style>

<div class="page-header">
  <div class="page-header-bg"></div>
  <div class="page-header-inner">
    <div class="page-header-label">Galeri Foto</div>
    <h1 class="page-header-title">Dakwah di<br><em style="color:#f0c040;font-style:italic">Setiap Tempat</em></h1>
    <p class="page-header-sub">Koleksi gambar dakwah lapangan, interfaith, program dakwah dan ceramah BroHafizi dari seluruh Malaysia.</p>
  </div>
</div>

<div class="filter-bar">
  <div class="filter-inner">
    <button class="filter-btn active" onclick="window.filterGallery('all',this)">Semua <span class="filter-count" id="count-all"></span></button>
    <button class="filter-btn" onclick="window.filterGallery('street',this)">Street Dakwah <span class="filter-count" id="count-street"></span></button>
    <button class="filter-btn" onclick="window.filterGallery('interfaith',this)">Interfaith <span class="filter-count" id="count-interfaith"></span></button>
    <button class="filter-btn" onclick="window.filterGallery('program',this)">Program Dakwah <span class="filter-count" id="count-program"></span></button>
    <button class="filter-btn" onclick="window.filterGallery('ceramah',this)">Ceramah <span class="filter-count" id="count-ceramah"></span></button>
    <button class="filter-btn" onclick="window.filterGallery('korporat',this)">Korporat <span class="filter-count" id="count-korporat"></span></button>
    <button class="filter-btn" onclick="window.filterGallery('tokoh',this)">Bersama Tokoh <span class="filter-count" id="count-tokoh"></span></button>
  </div>
</div>

<div class="gallery-main">

  <section class="gallery-section" id="section-street">
    <div class="section-header">
      <div class="section-title">Street Dakwah</div>
      <div class="section-badge" id="label-street"></div>
    </div>
    <p class="section-desc">Turun ke jalanan, berdepan dengan non-Muslim, menjawab persoalan tentang Islam secara langsung. Inilah dakwah yang sebenar-benarnya.</p>
    <div class="masonry-grid" id="grid-street"></div>
  </section>

  <section class="gallery-section" id="section-interfaith">
    <div class="section-header">
      <div class="section-title">Interfaith</div>
      <div class="section-badge" id="label-interfaith"></div>
    </div>
    <p class="section-desc">Berdialog, bukan berdebat. Program bersama komuniti bukan Islam untuk membina jambatan kefahaman dan memperkenalkan Islam dengan penuh hikmah.</p>
    <div class="masonry-grid" id="grid-interfaith"></div>
  </section>

  <section class="gallery-section" id="section-program">
    <div class="section-header">
      <div class="section-title">Program Dakwah</div>
      <div class="section-badge" id="label-program"></div>
    </div>
    <p class="section-desc">Dijemput sebagai penceramah dan fasilitator dalam pelbagai program, kursus dan latihan daripada pelbagai penganjur seperti agensi agama, NGO dan pelbagai organisasi membawa pengisian dakwah yang berimpak kepada peserta dari seluruh Malaysia.</p>
    <div class="masonry-grid" id="grid-program"></div>
  </section>

  <section class="gallery-section" id="section-ceramah">
    <div class="section-header">
      <div class="section-title">Ceramah</div>
      <div class="section-badge" id="label-ceramah"></div>
    </div>
    <p class="section-desc">Dari masjid ke surau, dari utara ke selatan. Dijemput untuk menyampaikan ceramah bertema dakwah kontemporari, hubungan Islam dengan bukan Muslim, dan cabaran umat di era digital.</p>
    <div class="masonry-grid" id="grid-ceramah"></div>
  </section>

  <section class="gallery-section" id="section-korporat">
    <div class="section-header">
      <div class="section-title">Korporat &amp; Training</div>
      <div class="section-badge" id="label-korporat"></div>
    </div>
    <p class="section-desc">Koleksi gambar profesional BroHafizi untuk tujuan publisiti, jemputan program, bengkel dan ceramah korporat.</p>
    <div class="masonry-grid" id="grid-korporat"></div>
  </section>

  <section class="gallery-section" id="section-tokoh">
    <div class="section-header">
      <div class="section-title">Bersama Tokoh &amp; Ulama</div>
      <div class="section-badge" id="label-tokoh"></div>
    </div>
    <p class="section-desc">Menimba ilmu dan bersama para ulama, mufti dan tokoh agama adalah antara nikmat terbesar dalam perjalanan dakwah.</p>
    <div class="masonry-grid" id="grid-tokoh"></div>
  </section>

</div>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="window.closeLightbox(event)">
  <div class="lb-inner">
    <img class="lb-img" id="lb-img" src="" alt="">
  </div>
  <button class="lb-close" onclick="window.closeLb()">&times;</button>
  <button class="lb-nav lb-prev" onclick="window.lbNav(-1)">&#8249;</button>
  <button class="lb-nav lb-next" onclick="window.lbNav(1)">&#8250;</button>
  <div class="lb-caption" id="lb-caption"></div>
  <div class="lb-counter" id="lb-counter"></div>
</div>

