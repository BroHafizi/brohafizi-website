  {id:'ceramah', title:'Ceramah', desc:'Sesi ceramah dan penyampaian yang dihadiri pelbagai lapisan pendengar di masjid, institusi pendidikan, organisasi korporat dan komuniti setempat.'},
  {id:'tokoh', title:'Bersama Tokoh dan Ulama', desc:'Rakaman berharga bersama tokoh terkemuka, mufti, pengarah institusi dan ulama berpengaruh dalam bidang dakwah dan pendidikan Islam di Malaysia.'},
  {id:'korporat', title:'Korporat', desc:'Koleksi gambar profesional BroHafizi untuk keperluan korporat, media sosial, laman web dan bahan promosi dalam kapasiti sebagai pelatih, strategist dan pendakwah digital.'}
];

var currentFilter = 'all';
var lbCurrent = 0;

window.renderGallery = function() {
  var main = document.getElementById('gallery-main');
  main.innerHTML = '';
  var toShow = currentFilter === 'all' ? sections : sections.filter(s => s.id === currentFilter);
  toShow.forEach(function(section) {
    var filtered = allGalleryData.filter(img => img.category === section.id);
    var sectionDiv = document.createElement('div');
    sectionDiv.className = 'gallery-section active';
    var headerDiv = document.createElement('div');
    headerDiv.className = 'section-header';
    headerDiv.innerHTML = '<h2 class="section-title">' + section.title + '</h2><p class="section-desc">' + section.desc + '</p>';
    var gridDiv = document.createElement('div');
    gridDiv.className = 'masonry-grid';
    filtered.forEach(function(img) {
      var item = document.createElement('div');
      item.className = 'masonry-item';
      item.innerHTML = '<img src="' + img.url + '" alt="' + img.caption + '"><div class="masonry-overlay"><div class="masonry-caption">' + img.caption + '</div></div>';
      item.onclick = function() { window.openLightbox(allGalleryData.indexOf(img)); };
      gridDiv.appendChild(item);
    });
    sectionDiv.appendChild(headerDiv);
    sectionDiv.appendChild(gridDiv);
    main.appendChild(sectionDiv);
  });
};

window.filterCategory = function(cat) {
  currentFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
  event.target.classList.add('active');
  window.renderGallery();
};

window.openLightbox = function(idx) {
  lbCurrent = idx;
  var img = allGalleryData[idx];
  document.getElementById('lb-img').src = img.url;
  document.getElementById('lb-caption').textContent = img.caption;
  document.getElementById('lb-counter').textContent = (idx + 1) + ' / ' + allGalleryData.length;
  document.getElementById('lightbox').classList.add('active');
  document.body.style.overflow = 'hidden';
};

window.closeLightbox = function(e) {
  if (!e || e.target.id === 'lightbox' || e.target.classList.contains('lb-close')) {
    document.getElementById('lightbox').classList.remove('active');
    document.body.style.overflow = '';
  }
};

window.lbNav = function(d) {
  lbCurrent = (lbCurrent + d + allGalleryData.length) % allGalleryData.length;
  var img = allGalleryData[lbCurrent];
  document.getElementById('lb-img').src = img.url;
  document.getElementById('lb-caption').textContent = img.caption;
  document.getElementById('lb-counter').textContent = (lbCurrent + 1) + ' / ' + allGalleryData.length;
};

document.addEventListener('keydown', function(e) {
  var lb = document.getElementById('lightbox');
  if (lb && lb.classList.contains('active')) {
    if (e.key === 'ArrowLeft') window.lbNav(-1);
    if (e.key === 'ArrowRight') window.lbNav(1);
    if (e.key === 'Escape') window.closeLightbox();
  }
});

window.renderGallery();
</script>

</Layout>
