var allPhotos = [];
var currentIndex = 0;

function buildMasonry(gridId, photos, section) {
  var grid = document.getElementById(gridId);
  if (!grid) return;
  grid.innerHTML = photos.map(function(p, i) {
    return '<div class="masonry-item" onclick="window.openLightbox(' + allPhotos.length + ')">'
      + '<img src="' + p.url + '" alt="' + p.caption + '" loading="lazy">'
      + '<div class="masonry-overlay"><div class="masonry-caption">' + p.caption + '</div></div>'
      + '</div>';
    allPhotos.push({url: p.url, caption: p.caption, section: section});
  }).join('');
  // Fix: rebuild with correct indices after allPhotos is populated
}

function rebuildMasonry(gridId, photos, startIndex, section) {
  var grid = document.getElementById(gridId);
  if (!grid) return;
  grid.innerHTML = photos.map(function(p, i) {
    return '<div class="masonry-item" onclick="window.openLightbox(' + (startIndex + i) + ')">'
      + '<img src="' + p.url + '" alt="' + p.caption + '" loading="lazy">'
      + '<div class="masonry-overlay"><div class="masonry-caption">' + p.caption + '</div></div>'
      + '</div>';
  }).join('');
}

document.addEventListener('DOMContentLoaded', function() {
  // Build allPhotos array first
  var sections = [
    {id:'grid-street', photos:window.streetPhotos, label:'street', title:'Street Dakwah'},
    {id:'grid-interfaith', photos:window.interfaithPhotos, label:'interfaith', title:'Interfaith'},
    {id:'grid-program', photos:window.programPhotos, label:'program', title:'Program Dakwah'},
    {id:'grid-ceramah', photos:window.ceramahPhotos, label:'ceramah', title:'Ceramah'},
    {id:'grid-korporat', photos:window.korporatPhotos, label:'korporat', title:'Korporat & Training'},
    {id:'grid-tokoh', photos:window.tokohPhotos, label:'tokoh', title:'Bersama Tokoh & Ulama'}
  ];

  var idx = 0;
  sections.forEach(function(s) {
    s.photos.forEach(function(p) {
      allPhotos.push({url:p.url, caption:p.caption, section:s.title});
    });
  });

  // Now build grids with correct indices
  idx = 0;
  sections.forEach(function(s) {
    rebuildMasonry(s.id, s.photos, idx, s.title);
    var countEl = document.getElementById('count-' + s.label);
    var labelEl = document.getElementById('label-' + s.label);
    if (countEl) countEl.textContent = s.photos.length;
    if (labelEl) labelEl.textContent = s.photos.length + ' gambar';
    idx += s.photos.length;
  });

  var countAll = document.getElementById('count-all');
  if (countAll) countAll.textContent = allPhotos.length;
});

window.filterGallery = function(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  var sections = ['street','interfaith','program','ceramah','korporat','tokoh'];
  sections.forEach(function(s) {
    var sec = document.getElementById('section-' + s);
    if (cat === 'all' || cat === s) {
      sec.classList.remove('hidden');
    } else {
      sec.classList.add('hidden');
    }
  });
};

window.openLightbox = function(index) {
  currentIndex = index;
  var photo = allPhotos[index];
  document.getElementById('lb-img').src = photo.url;
  document.getElementById('lb-caption').textContent = photo.caption;
  document.getElementById('lb-counter').textContent = (index + 1) + ' / ' + allPhotos.length;
  document.getElementById('lightbox').classList.add('active');
  document.body.style.overflow = 'hidden';
};

window.closeLb = function() {
  document.getElementById('lightbox').classList.remove('active');
  document.body.style.overflow = '';
};

window.closeLightbox = function(e) {
  if (e.target === document.getElementById('lightbox')) {
    window.closeLb();
  }
};

window.lbNav = function(dir) {
  currentIndex = (currentIndex + dir + allPhotos.length) % allPhotos.length;
  window.openLightbox(currentIndex);
};

document.addEventListener('keydown', function(e) {
  if (!document.getElementById('lightbox').classList.contains('active')) return;
  if (e.key === 'ArrowLeft') window.lbNav(-1);
  if (e.key === 'ArrowRight') window.lbNav(1);
  if (e.key === 'Escape') window.closeLb();
});
</script>

