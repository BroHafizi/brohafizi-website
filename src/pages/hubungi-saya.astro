<script>function handleSubmit(e) {
  e.preventDefault();
  var form = document.getElementById("contactForm");
  var inputs = form.querySelectorAll('input[type="text"]');
  var nama    = inputs[0] ? inputs[0].value : '';
  var org     = inputs[1] ? inputs[1].value : '';
  var tarikh  = inputs[2] ? inputs[2].value : '';
  var tel     = form.querySelector('input[type="tel"]').value;
  var email   = form.querySelector('input[type="email"]') ? form.querySelector('input[type="email"]').value : '';
  var program = form.querySelector('select').value;
  var mesej   = form.querySelector('textarea').value;

  // ── Step 1: Send to Formspree (data masuk email) ──
  var formData = new FormData();
  formData.append('Nama', nama);
  formData.append('Organisasi', org);
  formData.append('No_Telefon', tel);
  formData.append('Email', email);
  formData.append('Jenis_Program', program);
  formData.append('Tarikh_Program', tarikh);
  formData.append('Mesej', mesej);

  fetch('https://formspree.io/f/mjgzllwg', {
    method: 'POST',
    body: formData,
    headers: { 'Accept': 'application/json' }
  }).then(function(res) {
    console.log('Formspree:', res.ok ? 'OK' : 'Error');
  }).catch(function(err) {
    console.log('Formspree error:', err);
  });

  // ── Step 2: Build WhatsApp message ──
  var msg = "Assalamualaikum BroHafizi,%0A%0A";
  msg += "Saya ingin membuat pertanyaan:%0A%0A";
  msg += "Nama: " + encodeURIComponent(nama) + "%0A";
  if (org)     msg += "Organisasi: " + encodeURIComponent(org) + "%0A";
  msg += "No. Tel: " + encodeURIComponent(tel) + "%0A";
  if (email)   msg += "Email: " + encodeURIComponent(email) + "%0A";
  msg += "Program: " + encodeURIComponent(program) + "%0A";
  if (tarikh)  msg += "Tarikh: " + encodeURIComponent(tarikh) + "%0A";
  msg += "%0AMesej:%0A" + encodeURIComponent(mesej);

  // ── Step 3: Show success ──
  form.style.display = "none";
  document.getElementById("formSuccess").style.display = "block";
  window.scrollTo({top: document.getElementById("formSuccess").offsetTop - 100, behavior: "smooth"});

  // ── Step 4: Open WhatsApp after short delay ──
  setTimeout(function() {
    window.open("https://wa.me/60116490493?text=" + msg, "_blank");
  }, 900);
}

function toggleFaq(el) {
  var item = el.parentElement;
  var isOpen = item.classList.contains("open");
  document.querySelectorAll(".faq-item").forEach(function(i) { i.classList.remove("open"); });
  if (!isOpen) item.classList.add("open");
}</script>

