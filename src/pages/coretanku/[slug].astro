        </div>
      </div>

      <!-- Widget: Archives -->
      <div class="sidebar-widget">
        <div class="widget-title">Arkib</div>
        <div class="widget-body">
          <ul class="archive-list">
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2026-02">Februari 2026 <span class="archive-count">4</span></a></li>
