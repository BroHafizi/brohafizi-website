---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.(md|mdoc)$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const months: Record<string, string> = {
  '01':'Jan','02':'Feb','03':'Mac','04':'Apr','05':'Mei','06':'Jun',
  '07':'Jul','08':'Ogos','09':'Sep','10':'Okt','11':'Nov','12':'Dis'
};

function formatDate(dateStr: string) {
  const parts = dateStr.split('-');
  if (parts.length === 3) {
    return `${parseInt(parts[2])} ${months[parts[1]] || parts[1]} ${parts[0]}`;
  }
  return dateStr;
}

const catColors: Record<string, string> = {
  "Dakwah":"#1a56db","Artikel Dakwah":"#1a56db","Artikel Islam":"#059669",
  "Kursus":"#7c3aed","Kursus Istitabah":"#7c3aed","Social Media":"#dc2626",
  "Persoalan tentang Islam":"#d97706","Tips Dakwah":"#0891b2","Dakwah Digital":"#db2777"
};

const slug = post.id.replace(/\.(md|mdoc)$/, '');
---

<Layout 
  title={`${post.data.title} | BroHafizi`}
  description={post.data.excerpt || post.data.title}
  canonical={`https://brohafizi.com/coretanku/${slug}`}
>

<style is:global>
/* ── HEADER ── */
.article-header{background:#0d1b3e;padding:56px 5% 48px;position:relative;overflow:hidden}
.article-header-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0d1b3e 0%,#162d5e 50%,#0d1b3e 100%)}
.article-header-inner{position:relative;z-index:2;max-width:1200px;margin:0 auto}
.breadcrumb{display:flex;align-items:center;gap:8px;margin-bottom:16px;flex-wrap:wrap}
.breadcrumb a{color:#6b8dba;font-size:12px;text-decoration:none}
.breadcrumb a:hover{color:#f0c040}
.breadcrumb span{color:#3a5070;font-size:12px}
.article-cats{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px}
.article-cat{font-size:11px;padding:3px 10px;border-radius:12px;font-weight:500}
.article-title{font-family:"Playfair Display",serif;font-size:clamp(22px,4vw,40px);font-weight:700;color:#fff;line-height:1.2;letter-spacing:-0.5px;margin-bottom:16px}
.article-meta{display:flex;align-items:center;gap:16px;font-size:12px;color:#6b8dba;flex-wrap:wrap}

/* ── FEATURED IMAGE ── */
.featured-img-wrap{max-width:1200px;margin:0 auto;padding:0 5%}
.featured-img-wrap img{width:100%;max-height:460px;object-fit:cover;border-radius:0 0 8px 8px;display:block}

/* ── MAIN LAYOUT: content + sidebar ── */
.article-layout{max-width:1200px;margin:0 auto;padding:40px 5% 60px;display:grid;grid-template-columns:1fr 300px;gap:40px;align-items:start}

/* ── ARTICLE CONTENT ── */
.article-content{font-size:16px;line-height:1.9;color:#333}
.article-content h2{font-family:"Playfair Display",serif;font-size:22px;font-weight:700;color:#0d1b3e;margin:32px 0 12px;line-height:1.3}
.article-content h3{font-family:"Playfair Display",serif;font-size:18px;font-weight:600;color:#0d1b3e;margin:24px 0 10px}
.article-content p{margin-bottom:18px}
.article-content img{width:100%;border-radius:6px;margin:20px 0;display:block}
.article-content ul,.article-content ol{margin:12px 0 18px 24px}
.article-content li{margin-bottom:6px;line-height:1.7}
.article-content strong{color:#0d1b3e;font-weight:600}
.article-content a{color:#1a56db;text-decoration:underline}
.article-content blockquote{border-left:3px solid #f0c040;padding:12px 20px;margin:24px 0;background:#f8f6f0;border-radius:0 6px 6px 0;font-style:italic;color:#555}

/* ── ARTICLE FOOTER ── */
.article-footer{border-top:1px solid #e8e4dc;padding-top:28px;margin-top:40px}
.article-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px}
.article-tag{font-size:11px;padding:4px 10px;border-radius:12px;background:#f0ede8;color:#666;text-decoration:none}
.author-box{background:#f8f6f0;border:1px solid #e8e4dc;border-radius:8px;padding:20px;display:flex;align-items:center;gap:16px;margin-top:28px}
.author-avatar{width:48px;height:48px;border-radius:50%;background:#0d1b3e;display:flex;align-items:center;justify-content:center;color:#f0c040;font-size:16px;font-weight:700;flex-shrink:0}
.author-name{font-size:13px;font-weight:600;color:#0d1b3e}
.author-desc{font-size:12px;color:#777;margin-top:3px;line-height:1.5}
.article-nav{display:flex;justify-content:space-between;align-items:center;margin-top:24px;flex-wrap:wrap;gap:12px}
.btn-back{background:#0d1b3e;color:#fff;padding:10px 20px;border-radius:4px;font-size:13px;font-weight:500;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all 0.15s}
.btn-back:hover{background:#162d5e}

/* ── SIDEBAR ── */
.sidebar{display:flex;flex-direction:column;gap:24px;position:sticky;top:80px}
.sidebar-widget{background:#fff;border:1px solid #e8e4dc;border-radius:8px;overflow:hidden}
.widget-title{font-family:"Playfair Display",serif;font-size:14px;font-weight:700;color:#fff;background:#0d1b3e;padding:12px 16px;letter-spacing:0.3px;border-bottom:2px solid #f0c040}
.widget-body{padding:16px}

/* Artikel Terkini */
.recent-post{display:flex;gap:10px;padding:10px 0;border-bottom:1px solid #f0ede8;text-decoration:none;align-items:flex-start}
.recent-post:last-child{border-bottom:none;padding-bottom:0}
.recent-post:first-child{padding-top:0}
.recent-thumb{width:60px;height:50px;object-fit:cover;border-radius:4px;flex-shrink:0;background:#e8edf5}
.recent-thumb-ph{width:60px;height:50px;border-radius:4px;flex-shrink:0;background:linear-gradient(135deg,#e8edf5,#d0daea);display:flex;align-items:center;justify-content:center}
.recent-info{flex:1;min-width:0}
.recent-title{font-size:12px;font-weight:600;color:#0d1b3e;line-height:1.4;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;margin-bottom:4px}
.recent-post:hover .recent-title{color:#1a56db}
.recent-date{font-size:10px;color:#aaa}

/* Kategori */
.cat-list{list-style:none;padding:0;margin:0}
.cat-item{border-bottom:1px solid #f0ede8}
.cat-item:last-child{border-bottom:none}
.cat-link{display:flex;justify-content:space-between;align-items:center;padding:9px 0;text-decoration:none;font-size:13px;color:#444;transition:color 0.15s}
.cat-link:hover{color:#1a56db}
.cat-count{font-size:11px;background:#f0ede8;color:#888;padding:2px 7px;border-radius:10px;font-weight:500}

/* Archives */
.archive-list{list-style:none;padding:0;margin:0}
.archive-item{border-bottom:1px solid #f0ede8}
.archive-item:last-child{border-bottom:none}
.archive-link{display:flex;justify-content:space-between;align-items:center;padding:9px 0;text-decoration:none;font-size:13px;color:#444;transition:color 0.15s}
.archive-link:hover{color:#1a56db}
.archive-count{font-size:11px;background:#f0ede8;color:#888;padding:2px 7px;border-radius:10px}

/* Iklan */
.ad-slot{background:linear-gradient(135deg,#f8f6f0,#eee9e0);border-radius:6px;padding:24px 16px;text-align:center;min-height:200px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;border:1px dashed #ccc8bf}
.ad-label{font-size:10px;color:#bbb;letter-spacing:2px;text-transform:uppercase;margin-bottom:4px}
.ad-placeholder{font-size:13px;color:#aaa;line-height:1.5}
.ad-size{font-size:11px;color:#ccc;margin-top:4px}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .article-layout{grid-template-columns:1fr}
  .sidebar{position:static}
}
</style>

<header class="article-header">
  <div class="article-header-bg"></div>
  <div class="article-header-inner">
    <nav class="breadcrumb">
      <a href="/">Laman Utama</a>
      <span>/</span>
      <a href="/coretanku">Coretanku</a>
      <span>/</span>
      <span style="color:#adc5de">{post.data.title.substring(0,45)}{post.data.title.length > 45 ? '...' : ''}</span>
    </nav>
    <div class="article-cats">
      {post.data.categories.slice(0,3).map((cat: string) => (
        <span class="article-cat" style={`background:${(catColors[cat] || '#6b7280')}20;color:${catColors[cat] || '#6b7280'}`}>
          {cat}
        </span>
      ))}
    </div>
    <h1 class="article-title">{post.data.title}</h1>
    <div class="article-meta">
      <span>{formatDate(post.data.date)}</span>
      <span>&bull;</span>
      <span>{post.data.author}</span>
    </div>
  </div>
</header>

<main>
  <div class="article-layout">

    <!-- CONTENT -->
    <div>
      <div class="article-content">
        <Content />
      </div>
      <div class="article-footer">
        {post.data.tags.length > 0 && (
          <div class="article-tags">
            {post.data.tags.map((tag: string) => (
              <span class="article-tag">#{tag}</span>
            ))}
          </div>
        )}
        <div class="author-box">
          <img class="author-avatar" src="https://res.cloudinary.com/dqiqvxcy0/image/upload/q_auto/f_auto/v1780154248/Author_-_Bro_Hafizi_ysre5w.png" alt="Bro Hafizi" style="object-fit:cover;">
          <div>
            <div class="author-name">Penulis — Bro Hafizi</div>
            <div class="author-desc">Pendakwah Digital • AI Strategist • Trainer. Membantu organisasi dan komuniti menggunakan teknologi AI untuk dakwah yang lebih berimpak.</div>
          </div>
        </div>
        <div class="article-nav">
          <a href="/coretanku" class="btn-back">&larr; Kembali ke Coretanku</a>
          <a href="/hubungi-saya" style="font-size:13px;color:#1a56db;text-decoration:none">Jemput BroHafizi &rarr;</a>
        </div>
      </div>
    </div>

    <!-- SIDEBAR -->
    <aside class="sidebar">

      <!-- Widget: Artikel Terkini -->
      <div class="sidebar-widget">
        <div class="widget-title">Artikel Terkini</div>
        <div class="widget-body" id="recentPostsWidget">
          <div style="font-size:12px;color:#aaa;text-align:center;padding:10px 0">Memuatkan...</div>
        </div>
      </div>

      <!-- Widget: Iklan 1 -->
      <div class="sidebar-widget">
        <div class="widget-title">Promosi</div>
        <div class="widget-body" style="padding:0">
          <a href="/hubungi-saya" title="Bengkel Dakwah Digital">
            <img 
              src="https://res.cloudinary.com/dqiqvxcy0/image/upload/q_auto/f_auto/v1780398336/Iklan_-_Bengkel_Dakwah_Digital_3x_l2txdc.gif" 
              alt="Bengkel Dakwah Digital - BroHafizi"
              width="300" height="250"
              style="width:100%;height:auto;display:block;border-radius:0 0 8px 8px"
            >
          </a>
        </div>
      </div>

      <!-- Widget: Kategori -->
      <div class="sidebar-widget">
        <div class="widget-title">Kategori</div>
        <div class="widget-body">
          <ul class="cat-list">
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Dakwah">Dakwah <span class="cat-count">43</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Kursus">Kursus <span class="cat-count">19</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Kursus Dakwah">Kursus Dakwah <span class="cat-count">14</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Artikel Dakwah">Artikel Dakwah <span class="cat-count">9</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Persoalan tentang Islam">Soalan Islam <span class="cat-count">8</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Social Media">Social Media <span class="cat-count">8</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Artikel Islam">Artikel Islam <span class="cat-count">5</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Kursus Istitabah">Kursus Istitabah <span class="cat-count">5</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Tips Dakwah">Tips Dakwah <span class="cat-count">4</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Islam %26 Sains">Islam &amp; Sains <span class="cat-count">4</span></a></li>
            <li class="cat-item"><a class="cat-link" href="/coretanku?cat=Dakwah Digital">Dakwah Digital <span class="cat-count">2</span></a></li>
          </ul>
        </div>
      </div>

      <!-- Widget: Archives -->
      <div class="sidebar-widget">
        <div class="widget-title">Arkib</div>
        <div class="widget-body">
          <ul class="archive-list">
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2026-02">Februari 2026 <span class="archive-count">4</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2025-12">Disember 2025 <span class="archive-count">3</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2025-10">Oktober 2025 <span class="archive-count">2</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2025-08">Ogos 2025 <span class="archive-count">3</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2025-06">Jun 2025 <span class="archive-count">2</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2024-08">Ogos 2024 <span class="archive-count">9</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2024-06">Jun 2024 <span class="archive-count">7</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2024-05">Mei 2024 <span class="archive-count">5</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2024-03">Mac 2024 <span class="archive-count">14</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2024-02">Februari 2024 <span class="archive-count">4</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2023-12">Disember 2023 <span class="archive-count">1</span></a></li>
            <li class="archive-item"><a class="archive-link" href="/coretanku?bulan=2023-10">Oktober 2023 <span class="archive-count">2</span></a></li>
          </ul>
        </div>
      </div>

      <!-- Widget: Iklan 2 -->
      <div class="sidebar-widget">
        <div class="widget-title">Promosi</div>
        <div class="widget-body" style="padding:0">
          <a href="/hubungi-saya" title="Bengkel AI For Office">
            <img 
              src="https://res.cloudinary.com/dqiqvxcy0/image/upload/v1780400711/Iklan_-_Bengkel_AI_For_Office_loauhk.gif" 
              alt="Bengkel AI For Office - BroHafizi"
              width="300" height="125"
              style="width:100%;height:auto;display:block;border-radius:0 0 8px 8px"
            >
          </a>
        </div>
      </div>

    </aside>
  </div>
</main>

<script is:inline>
document.addEventListener("DOMContentLoaded", function() {
  fetch("/posts.json")
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var widget = document.getElementById("recentPostsWidget");
      if (!widget) return;
      var recent = data.slice(0, 5);
      widget.innerHTML = recent.map(function(p) {
        var img = p.img
          ? '<img class="recent-thumb" src="' + p.img + '" alt="" loading="lazy">'
          : '<div class="recent-thumb-ph"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ab0cc" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/></svg></div>';
        return '<a class="recent-post" href="' + p.link + '">'
          + img
          + '<div class="recent-info">'
          + '<div class="recent-title">' + p.title + '</div>'
          + '<div class="recent-date">' + p.dateDisplay + '</div>'
          + '</div></a>';
      }).join("");
    })
    .catch(function() {
      var widget = document.getElementById("recentPostsWidget");
      if (widget) widget.innerHTML = '<div style="font-size:12px;color:#aaa;text-align:center;padding:10px 0">Tiada artikel.</div>';
    });
});
</script>

</Layout>