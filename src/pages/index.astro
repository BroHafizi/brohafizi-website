<script is:inline>(function(){
  var track = document.getElementById("testiTrack");
  var cards = track.querySelectorAll(".testi-card");
  var dotsEl = document.getElementById("testiDots");
  var current = 0;
  var autoTimer;

  function getVisible(){ return window.innerWidth > 900 ? 2 : 1; }
  function getMax(){ return Math.max(0, cards.length - getVisible()); }

  function setWidths(){
    var vis = getVisible();
    var gap = 20;
    var tw = track.parentElement.offsetWidth;
    var cw = (tw - gap*(vis-1)) / vis;
    for(var i=0;i<cards.length;i++) cards[i].style.width = cw+"px";
  }

  function buildDots(){
    dotsEl.innerHTML = "";
    var max = getMax();
    for(var i=0;i<=max;i++){
      var d = document.createElement("div");
      d.className = "testi-dot" + (i===current?" active":"");
      (function(idx){ d.onclick = function(){ goTo(idx); }; })(i);
      dotsEl.appendChild(d);
    }
  }

  function goTo(idx){
    var max = getMax();
    current = Math.max(0, Math.min(idx, max));
    var cw = cards[0].offsetWidth + 20;
    track.style.transform = "translateX(-"+(current*cw)+"px)";
    var dots = dotsEl.querySelectorAll(".testi-dot");
    for(var i=0;i<dots.length;i++) dots[i].classList.toggle("active", i===current);
    resetTimer();
  }

  window.slideTestimonial = function(dir){ goTo(current+dir); };

  function resetTimer(){
    clearInterval(autoTimer);
    autoTimer = setInterval(function(){ goTo(current < getMax() ? current+1 : 0); }, 5000);
  }

  function init(){ setWidths(); buildDots(); goTo(0); resetTimer(); }
  init();
  window.addEventListener("resize", function(){ setWidths(); buildDots(); goTo(Math.min(current,getMax())); });
})();

// Load latest 4 posts from posts.json
(function(){
  fetch("/posts.json")
    .then(function(r){return r.json();})
    .then(function(posts){
      var grid = document.getElementById("homeBlogGrid");
      if(!grid) return;
      var catColors = {"Dakwah":"#1a56db","Artikel Dakwah":"#1a56db","Artikel Islam":"#059669","Kursus":"#7c3aed","Social Media":"#dc2626","Persoalan tentang Islam":"#d97706","Tips Dakwah":"#0891b2","Dakwah Digital":"#db2777"};
      var top4 = posts.slice(0,4);
      grid.innerHTML = top4.map(function(p){
        var cats = p.cats.slice(0,2).map(function(c){
          var col = catColors[c]||"#6b7280";
          return '<span class="blog-cat" style="background:'+col+'20;color:'+col+'">'+c+'</span>';
        }).join("");
        var imgHtml = p.img
          ? '<img src="'+p.img+'" alt="" style="width:100%;height:100%;object-fit:cover;display:block">'
          : '<svg viewBox="0 0 24 24" style="width:36px;height:36px;stroke:rgba(255,255,255,0.15);fill:none;stroke-width:1"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>';
        return '<a class="blog-card" href="'+p.link+'">'+
          '<div class="blog-card-img" style="overflow:hidden;position:relative">'+imgHtml+'<span class="date">'+p.dateDisplay+'</span></div>'+
          '<div class="blog-card-body">'+
            '<div class="blog-cats">'+cats+'</div>'+
            '<h3>'+p.title+'</h3>'+
            '<div class="blog-card-meta">'+p.dateDisplay+'</div>'+
          '</div>'+
        '</a>';
      }).join("");
    })
    .catch(function(e){ console.error("Blog load error:", e); });
})();
</script>

