---
export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}
const baseUrl = "https://brohafizi.com";
const { title, description = "BroHafizi — Trainer & Pendakwah Digital Malaysia", canonical, ogImage = `${baseUrl}/images/og-images/OG-Image-BroHafizi.png` } = Astro.props;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${baseUrl}${ogImage}`;
const currentPath = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="ms">
<head>
<link rel="icon" type="image/x-icon" href="/favicon.ico">
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
{canonical && <link rel="canonical" href={canonical}>}
<meta name="theme-color" content="#0d1b3e">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="website">
<meta property="og:image" content={ogImageUrl}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:url" content={canonical ?? "https://brohafizi.com"}>
<meta property="og:site_name" content="BroHafizi.com">
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImageUrl}>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,600;0,700;1,600;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style is:global>
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:"DM Sans",sans-serif;background:#f2f0eb;color:#1a1a2e;overflow-x:hidden}

/* NAV */
nav{background:#0d1b3e;display:flex;justify-content:space-between;align-items:center;padding:0 5%;height:64px;position:sticky;top:0;z-index:100}
.nav-brand{display:flex;flex-direction:column;gap:2px;text-decoration:none}
.nav-brand strong{color:#fff;font-size:16px;font-weight:600}
.nav-brand span{color:#6b8dba;font-size:10px;letter-spacing:1px;text-transform:uppercase}
.nav-links{display:flex;gap:2px}
.nav-links a{color:#adc5de;font-size:13px;padding:8px 14px;border-radius:4px;text-decoration:none;transition:all 0.15s}
.nav-links a:hover,.nav-links a.active{background:#1a2f5e;color:#fff}
.nav-right{display:flex;align-items:center;gap:8px}
.nav-social{display:flex;gap:6px}
.nav-social a{width:30px;height:30px;border:1px solid #1e3060;border-radius:4px;display:flex;align-items:center;justify-content:center;color:#6b8dba;text-decoration:none;font-size:12px;transition:all 0.15s}
.nav-social a:hover{background:#1a2f5e;color:#fff}

/* HAMBURGER */
.nav-hamburger{display:none;background:none;border:1px solid #1e3060;border-radius:4px;width:38px;height:38px;cursor:pointer;flex-direction:column;gap:5px;align-items:center;justify-content:center;padding:0}
.nav-hamburger span{display:block;width:18px;height:2px;background:#adc5de;border-radius:2px;transition:all 0.3s}
.nav-hamburger.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nav-hamburger.open span:nth-child(2){opacity:0}
.nav-hamburger.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* MOBILE MENU */
.mobile-menu{display:none;position:fixed;top:64px;left:0;right:0;background:#0d1b3e;border-top:1px solid #1a2f5e;z-index:99;flex-direction:column;box-shadow:0 8px 24px rgba(0,0,0,0.4)}
.mobile-menu.open{display:flex}
.mobile-menu a{color:#adc5de;font-size:14px;padding:16px 5%;text-decoration:none;border-bottom:1px solid #0a1530;transition:all 0.15s}
.mobile-menu a:hover,.mobile-menu a.active{background:#1a2f5e;color:#fff;padding-left:calc(5% + 8px)}
.mobile-menu a:last-child{border-bottom:none}

/* FOOTER */
footer{background:#060f22;padding:28px 5%;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px;border-top:1px solid #0d1b3e}
.footer-brand strong{color:#adc5de;font-size:13px}
.footer-brand span{display:block;font-size:10px;color:#2a4060;margin-top:2px}
.footer-copy{font-size:11px;color:#2a4060}

/* RESPONSIVE */
@media(max-width:768px){
  .nav-links{display:none}
  .nav-social{display:none}
  .nav-hamburger{display:flex}
}
</style>
</head>
<body>

<nav role="navigation" aria-label="Navigasi Utama">
  <a href="/" class="nav-brand">
    <strong>BroHafizi.com</strong>
    <span>Sebarkan Salam Sampaikan Islam</span>
  </a>
  <div class="nav-links">
    <a href="/" class={currentPath === "/" ? "active" : ""}>Laman Utama</a>
    <a href="/mengenai-saya" class={currentPath === "/mengenai-saya" ? "active" : ""}>Mengenai Saya</a>
    <a href="/coretanku" class={currentPath.startsWith("/coretanku") ? "active" : ""}>Coretanku</a>
    <a href="/galeri" class={currentPath === "/galeri" ? "active" : ""}>Galeri</a>
    <a href="/hubungi-saya" class={currentPath === "/hubungi-saya" ? "active" : ""}>Hubungi Saya</a>
  </div>
  <div class="nav-right">
    <div class="nav-social">
      <a href="https://www.facebook.com/BroHafizidotcom" target="_blank" rel="noopener">f</a>
      <a href="https://www.instagram.com/brotherhafizi/" target="_blank" rel="noopener">&#9678;</a>
      <a href="https://www.tiktok.com/@brohafizi.com" target="_blank" rel="noopener">&#9654;</a>
    </div>
    <button class="nav-hamburger" id="hamburgerBtn" onclick="toggleMenu()" aria-label="Buka Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/">Laman Utama</a>
  <a href="/mengenai-saya">Mengenai Saya</a>
  <a href="/coretanku">Coretanku</a>
  <a href="/galeri">Galeri</a>
  <a href="/hubungi-saya">Hubungi Saya</a>
</div>

<slot />

<footer role="contentinfo">
  <div class="footer-brand">
    <strong>BroHafizi.com</strong>
    <span>Sebarkan Salam Sampaikan Islam &middot; &copy; 2026</span>
  </div>
  <div class="footer-copy">Dibina dengan Astro &middot; Hosted on Vercel</div>
</footer>

<script is:inline>
function toggleMenu() {
  var menu = document.getElementById('mobileMenu');
  var btn = document.getElementById('hamburgerBtn');
  var isOpen = menu.classList.contains('open');
  if (isOpen) {
    menu.classList.remove('open');
    btn.classList.remove('open');
  } else {
    menu.classList.add('open');
    btn.classList.add('open');
  }
}

document.addEventListener('DOMContentLoaded', function() {
  // Set active link in mobile menu
  var path = window.location.pathname;
  var links = document.querySelectorAll('.mobile-menu a');
  links.forEach(function(link) {
    var href = link.getAttribute('href');
    if (href === path || (path.startsWith('/coretanku') && href === '/coretanku')) {
      link.classList.add('active');
    }
    // Close menu on link click
    link.addEventListener('click', function() {
      document.getElementById('mobileMenu').classList.remove('open');
      document.getElementById('hamburgerBtn').classList.remove('open');
    });
  });
});

// Close menu when clicking outside
document.addEventListener('click', function(e) {
  var menu = document.getElementById('mobileMenu');
  var btn = document.getElementById('hamburgerBtn');
  if (menu && menu.classList.contains('open')) {
    if (!menu.contains(e.target) && btn && !btn.contains(e.target)) {
      menu.classList.remove('open');
      btn.classList.remove('open');
    }
  }
});
</script>
</body>
</html>
